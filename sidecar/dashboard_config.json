{
  "dashboard": {
    "name": "OpenFeeder API Metrics",
    "description": "Comprehensive analytics for OpenFeeder sidecar API usage, performance, and bot activity",
    "widgets": [
      {
        "id": "requests-per-hour",
        "title": "Requests per Hour",
        "type": "line_chart",
        "metric": "pageviews",
        "description": "Total API requests over time",
        "groupBy": "hour",
        "filters": {
          "event_name": ["api.request"]
        },
        "position": {
          "x": 0,
          "y": 0,
          "width": 2,
          "height": 1
        }
      },
      {
        "id": "llm-bot-breakdown",
        "title": "LLM Bot Activity Breakdown",
        "type": "pie_chart",
        "description": "API requests by LLM bot family (Claude, GPT, Perplexity, etc.)",
        "groupBy": "bot_family",
        "filters": {
          "event_name": ["api.bot"],
          "bot_family": ["anthropic", "openai", "perplexity", "google", "cohere"]
        },
        "position": {
          "x": 2,
          "y": 0,
          "width": 1,
          "height": 1
        }
      },
      {
        "id": "rate-limit-timeline",
        "title": "Rate Limit Violations",
        "type": "area_chart",
        "description": "Number of rate limit hits over time",
        "groupBy": "hour",
        "filters": {
          "event_name": ["api.ratelimit"]
        },
        "position": {
          "x": 0,
          "y": 1,
          "width": 1,
          "height": 1
        }
      },
      {
        "id": "error-distribution",
        "title": "Error Distribution",
        "type": "bar_chart",
        "description": "API errors by type and HTTP status code",
        "groupBy": "error_type",
        "filters": {
          "event_name": ["api.error"]
        },
        "position": {
          "x": 1,
          "y": 1,
          "width": 1,
          "height": 1
        }
      },
      {
        "id": "response-time-percentiles",
        "title": "Response Time Percentiles",
        "type": "metric_chart",
        "description": "95th and 99th percentile response times in milliseconds",
        "metrics": [
          {
            "name": "p95_duration_ms",
            "label": "95th Percentile",
            "percentile": 95
          },
          {
            "name": "p99_duration_ms",
            "label": "99th Percentile",
            "percentile": 99
          }
        ],
        "filters": {
          "event_name": ["api.request"]
        },
        "position": {
          "x": 2,
          "y": 1,
          "width": 1,
          "height": 1
        }
      },
      {
        "id": "top-endpoints",
        "title": "Top API Endpoints",
        "type": "table",
        "description": "Most frequently accessed endpoints with request counts and avg response time",
        "columns": [
          {
            "name": "endpoint",
            "label": "Endpoint"
          },
          {
            "name": "requests",
            "label": "Requests",
            "type": "number",
            "sortable": true
          },
          {
            "name": "avg_duration_ms",
            "label": "Avg Duration (ms)",
            "type": "number",
            "sortable": true
          },
          {
            "name": "error_rate",
            "label": "Error Rate %",
            "type": "percentage",
            "sortable": true
          }
        ],
        "filters": {
          "event_name": ["api.request"]
        },
        "limit": 10,
        "position": {
          "x": 0,
          "y": 2,
          "width": 3,
          "height": 1
        }
      },
      {
        "id": "search-metrics",
        "title": "Search Performance",
        "type": "metrics_grid",
        "description": "Search query analytics",
        "metrics": [
          {
            "name": "total_searches",
            "label": "Total Searches",
            "aggregation": "count"
          },
          {
            "name": "avg_results",
            "label": "Avg Results per Query",
            "aggregation": "average"
          },
          {
            "name": "avg_search_duration",
            "label": "Avg Search Duration (ms)",
            "aggregation": "average"
          },
          {
            "name": "zero_result_searches",
            "label": "Zero-Result Searches",
            "aggregation": "count",
            "filter": "results_count = 0"
          }
        ],
        "filters": {
          "event_name": ["api.search"]
        },
        "position": {
          "x": 0,
          "y": 3,
          "width": 2,
          "height": 1
        }
      },
      {
        "id": "sync-metrics",
        "title": "Sync Statistics",
        "type": "metrics_grid",
        "description": "Differential sync activity",
        "metrics": [
          {
            "name": "total_syncs",
            "label": "Total Sync Requests",
            "aggregation": "count"
          },
          {
            "name": "total_added",
            "label": "Total Items Added",
            "aggregation": "sum",
            "field": "added"
          },
          {
            "name": "total_updated",
            "label": "Total Items Updated",
            "aggregation": "sum",
            "field": "updated"
          },
          {
            "name": "total_deleted",
            "label": "Total Items Deleted",
            "aggregation": "sum",
            "field": "deleted"
          }
        ],
        "filters": {
          "event_name": ["api.sync"]
        },
        "position": {
          "x": 2,
          "y": 3,
          "width": 1,
          "height": 1
        }
      }
    ]
  },
  "custom_events": {
    "api.request": {
      "description": "API request to OpenFeeder endpoints",
      "properties": {
        "endpoint": "API endpoint path (e.g., /openfeeder, /.well-known/openfeeder.json)",
        "method": "HTTP method (GET, POST, etc.)",
        "status_code": "HTTP response status code",
        "duration_ms": "Response time in milliseconds",
        "bot_name": "Identified bot name (e.g., ClaudeBot, GPTBot)",
        "bot_family": "Bot family classification (anthropic, openai, perplexity, etc.)",
        "user_agent_short": "First 100 chars of User-Agent header"
      }
    },
    "api.ratelimit": {
      "description": "Rate limit violation detected",
      "properties": {
        "client_ip_hash": "SHA256 hash of client IP (first 16 chars) for privacy",
        "endpoint": "API endpoint that was rate limited",
        "limit": "Rate limit per window",
        "remaining": "Remaining requests after this hit",
        "reset_timestamp": "Unix timestamp when limit resets"
      }
    },
    "api.error": {
      "description": "API error occurred",
      "properties": {
        "error_type": "Error class name (e.g., ValueError, IndexError)",
        "status_code": "HTTP status code returned",
        "message": "Error message (truncated to 200 chars)",
        "endpoint": "Endpoint where error occurred",
        "traceback": "Optional traceback for debugging (truncated to 500 chars)"
      }
    },
    "api.bot": {
      "description": "Activity from known LLM bots",
      "properties": {
        "bot_name": "Bot identifier (e.g., ClaudeBot)",
        "bot_family": "Bot family (e.g., anthropic, openai, perplexity)",
        "endpoint": "API endpoint accessed",
        "status_code": "Response status",
        "duration_ms": "Response time in milliseconds"
      }
    },
    "api.search": {
      "description": "Search query executed",
      "properties": {
        "query_hash": "SHA256 hash of query (first 16 chars) for privacy",
        "query_length": "Number of characters in query",
        "results_count": "Number of results returned",
        "duration_ms": "Search duration in milliseconds",
        "min_score_filter": "Score filter applied (if any)",
        "has_url_filter": "Whether a URL filter was applied"
      }
    },
    "api.sync": {
      "description": "Differential sync request",
      "properties": {
        "added": "Number of items added",
        "updated": "Number of items updated",
        "deleted": "Number of items deleted",
        "duration_ms": "Sync duration in milliseconds",
        "total": "Total items in sync (added + updated + deleted)"
      }
    }
  },
  "alerts": {
    "high_error_rate": {
      "name": "High Error Rate",
      "condition": "error_count > 10 in 1 hour",
      "severity": "warning",
      "message": "More than 10 errors detected in the past hour"
    },
    "rate_limit_abuse": {
      "name": "Rate Limit Abuse",
      "condition": "ratelimit_events > 50 in 1 hour",
      "severity": "critical",
      "message": "Excessive rate limit violations detected"
    },
    "slow_responses": {
      "name": "Slow Response Times",
      "condition": "p95_duration_ms > 5000",
      "severity": "warning",
      "message": "95th percentile response time exceeds 5 seconds"
    },
    "search_degradation": {
      "name": "Search Degradation",
      "condition": "zero_result_ratio > 0.5",
      "severity": "info",
      "message": "Over 50% of searches returning no results"
    }
  }
}
